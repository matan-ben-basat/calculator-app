pipeline {
    // הרצת שלבי המעטפת הכלליים על השרת המארח [cite: 21, 118]
    agent { label 'built-in' } 

    environment {
        AWS_ACCOUNT_ID     = '992382545251' 
        AWS_DEFAULT_REGION = 'us-east-1'
        ECR_REGISTRY       = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com"
        IMAGE_NAME         = 'calculator-app'
        PROD_SERVER_IP     = '100.53.73.171' // ה-IP המעודכן שלך [cite: 9, 49]
    }

    stages {
        // ==========================================================
        // חלק ג': תזרים CI עבור Pull Requests [cite: 11, 113]
        // ==========================================================
        stage('CI Flow - Pull Request') {
            when { changeRequest() } // ירוץ אוטומטית רק על בקשות מיזוג (PR) [cite: 34, 126]
            stages {
                stage('Build Image (PR)') {
                    steps {
                        // בנייה אחת ותיוג דטרמיניסטי מבוסס PR ו-Build [cite: 72, 82, 156, 163]
                        sh "docker build -t ${IMAGE_NAME}:pr-${CHANGE_ID}-${BUILD_NUMBER} ./calculator-app-v2"
                    }
                }
                stage('Test (PR)') {
                    agent {
                        docker { 
                            image 'python:3.11-slim' [cite: 21, 118]
                            reuseNode true 
                        }
                    }
                    steps {
                        dir('calculator-app-v2') {
                            // התקנת pytest וחבילות האפליקציה בתוך קונטיינר הבידוד [cite: 21, 118]
                            sh 'pip install pytest'
                            sh 'pip install --target=./packages -r requirements.txt'
                            // הרצה המייצרת דוח XML תקני עבור ג'נקינס [cite: 73, 156]
                            sh 'PYTHONPATH=./packages python -m pytest --junitxml=test-results.xml tests/'
                        }
                    }
                    post {
                        always {
                            // שמירת תוצאות הבדיקות והצגתן בממשק ג'נקינס לפי ה-DoD 
                            junit allowEmptyResults: true, testResults: '**/test-results.xml'
                        }
                    }
                }
                stage('Push to ECR (PR)') {
                    agent {
                        docker {
                            image 'amazon/aws-cli:latest' [cite: 21, 118]
                            args '-v /var/run/docker.sock:/var/run/docker.sock' // מיפוי מאובטח של ה-Socket [cite: 23, 119]
                            reuseNode true
                        }
                    }
                    steps {
                        withCredentials([
                            string(credentialsId: 'aws-access-key-id', variable: 'AWS_ACCESS_KEY_ID'),
                            string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                        ]) {
                            script {
                                sh "aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"
                                sh "docker tag ${IMAGE_NAME}:pr-${CHANGE_ID}-${BUILD_NUMBER} ${ECR_REGISTRY}/${IMAGE_NAME}:pr-${CHANGE_ID}-${BUILD_NUMBER}"
                                sh "docker push ${ECR_REGISTRY}/${IMAGE_NAME}:pr-${CHANGE_ID}-${BUILD_NUMBER}" [cite: 77, 159]
                            }
                        }
                    }
                }
            }
        }

        // ==========================================================
        // חלק ד': תזרים CD עבור Merge-to-Master [cite: 12, 113]
        // ==========================================================
        stage('CD Flow - Merge to Master') {
            when { branch 'main' } // מופעל אוטומטית במיזוג לענף הראשי [cite: 34, 126]
            stages {
                stage('Build Image (Prod)') {
                    steps {
                       sh "docker build -t ${IMAGE_NAME}:candidate-${BUILD_NUMBER} ./calculator-app-v2" [cite: 90, 171]
                    }
                }
                stage('Test (Prod)') {
                    agent {
                        docker { 
                            image 'python:3.11-slim' [cite: 21, 118]
                            reuseNode true 
                        }
                    }
                    steps {
                        dir('calculator-app-v2') {
                            sh 'pip install pytest'
                            sh 'pip install --target=./packages -r requirements.txt'
                            sh 'PYTHONPATH=./packages python -m pytest --junitxml=test-results.xml tests/' [cite: 91, 172]
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: '**/test-results.xml' [cite: 86, 166]
                        }
                    }
                }
                stage('Push to ECR (Prod)') {
                    agent {
                        docker {
                            image 'amazon/aws-cli:latest' [cite: 21, 118]
                            args '-v /var/run/docker.sock:/var/run/docker.sock' [cite: 23, 119]
                            reuseNode true
                        }
                    }
                    steps {
                        withCredentials([
                            string(credentialsId: 'aws-access-key-id', variable: 'AWS_ACCESS_KEY_ID'),
                            string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                        ]) {
                            script {
                                sh "aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"
                                sh "docker tag ${IMAGE_NAME}:candidate-${BUILD_NUMBER} ${ECR_REGISTRY}/${IMAGE_NAME}:candidate-${BUILD_NUMBER}"
                                sh "docker tag ${IMAGE_NAME}:candidate-${BUILD_NUMBER} ${ECR_REGISTRY}/${IMAGE_NAME}:latest"
                                sh "docker push ${ECR_REGISTRY}/${IMAGE_NAME}:candidate-${BUILD_NUMBER}" [cite: 92, 173]
                                sh "docker push ${ECR_REGISTRY}/${IMAGE_NAME}:latest"
                            }
                        }
                    }
                }
                stage('Deploy to Production') {
                    steps {
                        withCredentials([
                            sshUserPrivateKey(credentialsId: 'prod-ec2-ssh-key', keyFileVariable: 'IDENTITY_KEY', usernameVariable: 'USER'),
                            string(credentialsId: 'aws-access-key-id', variable: 'AWS_ACCESS_KEY_ID'),
                            string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                        ]) {
                            script {
                                // כתיבת הפקודה ישירות כבלוק טקסט נקי בלי שירשורים ידניים, פותר את בעיית ה-Escaping לחלוטין
                                def deployCmd = """
                                    aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY} && \
                                    docker pull ${ECR_REGISTRY}/${IMAGE_NAME}:candidate-${BUILD_NUMBER} && \
                                    docker stop ${IMAGE_NAME} || true && \
                                    docker rm ${IMAGE_NAME} || true && \
                                    docker run -d --name ${IMAGE_NAME} --restart always -p 80:5000 ${ECR_REGISTRY}/${IMAGE_NAME}:candidate-${BUILD_NUMBER}
                                """
                                
                                // העברת משתני ה-AWS ישירות דרך פקודת ה-SSH בצורה מובנית ומאובטחת למניעת קריסה בשאל
                                sh "ssh -o StrictHostKeyChecking=no -i \${IDENTITY_KEY} \${USER}@${PROD_SERVER_IP} 'AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID} AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY} ${deployCmd}'" [cite: 94, 173, 174]
                            }
                        }
                    }
                }
                stage('Health Verification') {
                    steps {
                        script {
                            def maxRetries = 5
                            def success = false
                            for(int i=0; i<maxRetries; i++) {
                                try {
                                    def status = sh(script: "curl -s -o /dev/null -w '%{http_code}' http://${PROD_SERVER_IP}/health", returnStdout: true).trim() [cite: 95, 176]
                                    if(status == "200") {
                                        success = true
                                        echo "Application is Healthy!"
                                        break
                                    }
                                } catch(Exception e) {
                                    echo "Waiting for app to spin up... (Attempt ${i+1}/${maxRetries})"
                                }
                                sleep(time: 10, unit: 'SECONDS') // מנגנון השהייה יציב שאינו נוטה לכשלים [cite: 102, 180]
                            }
                            if(!success) {
                                error "Health check failed! Production environment is unhealthy." [cite: 97, 176]
                            }
                        }
                    }
                }
            }
        }
    }
}
