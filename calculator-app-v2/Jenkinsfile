pipeline {
    agent { label 'built-in' } 

    environment {
        AWS_ACCOUNT_ID     = '992382545251' 
        AWS_DEFAULT_REGION = 'us-east-1'
        ECR_REGISTRY       = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com"
        IMAGE_NAME         = 'calculator-app'
        PROD_SERVER_IP     = '3.86.214.188' 
    }

    stages {
        // ==========================================
        // חלק ג': תזרים CI - רץ רק על Pull Requests
        // ==========================================
        stage('CI Flow - Pull Request') {
            when { changeRequest() } // מזהה אוטומטית PR מה-Webhook
            stages {
                stage('Build Image (PR)') {
                    steps {
                        // בנייה אחת עם תיוג דטרמיניסטי מבוסס PR ו-Build
                        sh "docker build -t ${IMAGE_NAME}:pr-${CHANGE_ID}-${BUILD_NUMBER} ./calculator-app-v2"
                    }
                }
                stage('Test (PR)') {
                    agent {
                        docker { 
                            image 'python:3.11-slim'
                            reuseNode true 
                        }
                    }
                    steps {
                        dir('calculator-app-v2') {
                            sh 'pip install --target=./packages -r requirements.txt'
                            sh 'PYTHONPATH=./packages python -m unittest discover -s tests -v'
                        }
                    }
                }
                stage('Push to ECR (PR)') {
                    steps {
                        script {
                            // שימוש ב-Instance Role - אפס מפתחות גלויים בקוד!
                            sh "aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"
                            sh "docker tag ${IMAGE_NAME}:pr-${CHANGE_ID}-${BUILD_NUMBER} ${ECR_REGISTRY}/${IMAGE_NAME}:pr-${CHANGE_ID}-${BUILD_NUMBER}"
                            sh "docker push ${ECR_REGISTRY}/${IMAGE_NAME}:pr-${CHANGE_ID}-${BUILD_NUMBER}"
                        }
                    }
                }
            }
        }

        // ==========================================
        // חלק ד': תזרים CD - רץ רק במיזוג ל-master/main
        // ==========================================
        stage('CD Flow - Merge to Master') {
            when { branch 'main' } // או 'master' בהתאם לבראנץ' הראשי שלך
            stages {
                stage('Build Image (Prod)') {
                    steps {
                       sh "docker build -t ${IMAGE_NAME}:candidate-${BUILD_NUMBER} ./calculator-app-v2"
                    }
                }
                stage('Test (Prod)') {
                    agent {
                        docker { 
                            image 'python:3.11-slim'
                            reuseNode true 
                        }
                    }
                    steps {
                        dir('calculator-app-v2') {
                            sh 'pip install --target=./packages -r requirements.txt'
                            sh 'PYTHONPATH=./packages python -m unittest discover -s tests -v'
                        }
                    }
                }
                stage('Push to ECR (Prod)') {
                    steps {
                        script {
                            // גם פה - נשענים על ה-IAM Role של השרת!
                            sh "aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"
                            sh "docker tag ${IMAGE_NAME}:candidate-${BUILD_NUMBER} ${ECR_REGISTRY}/${IMAGE_NAME}:candidate-${BUILD_NUMBER}"
                            sh "docker tag ${IMAGE_NAME}:candidate-${BUILD_NUMBER} ${ECR_REGISTRY}/${IMAGE_NAME}:latest"
                            sh "docker push ${ECR_REGISTRY}/${IMAGE_NAME}:candidate-${BUILD_NUMBER}"
                            sh "docker push ${ECR_REGISTRY}/${IMAGE_NAME}:latest"
                        }
                    }
                }
                stage('Deploy to Production') {
                    steps {
                        withCredentials([sshUserPrivateKey(credentialsId: 'prod-ec2-ssh-key', keyFileVariable: 'IDENTITY_KEY', usernameVariable: 'USER')]) {
                            script {
                                def deployCmd = """
                                    aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY} && \
                                    docker pull ${ECR_REGISTRY}/${IMAGE_NAME}:candidate-${BUILD_NUMBER} && \
                                    docker stop ${IMAGE_NAME} || true && \
                                    docker rm ${IMAGE_NAME} || true && \
                                    docker run -d --name ${IMAGE_NAME} --restart always -p 80:5000 ${ECR_REGISTRY}/${IMAGE_NAME}:candidate-${BUILD_NUMBER}
                                """
                                sh "ssh -o StrictHostKeyChecking=no -i \${IDENTITY_KEY} \${USER}@${PROD_SERVER_IP} '${deployCmd}'"
                            }
                        }
                    }
                }
                stage('Health Verification') {
                    steps {
                        script {
                            def maxRetries = 5 // הגדלתי ל-5 כדי שיהיה פחות רגיש לכשלים אקראיים (Non-flaky)
                            def success = false
                            for(int i=0; i<maxRetries; i++) {
                                try {
                                    def status = sh(script: "curl -s -o /dev/null -w '%{http_code}' http://${PROD_SERVER_IP}/health", returnStdout: true).trim()
                                    if(status == "200") {
                                        success = true
                                        echo "Application is Healthy!"
                                        break
                                    }
                                } catch(Exception e) {
                                    echo "Waiting for app to spin up..."
                                }
                                sleep(time: 10, unit: 'SECONDS')
                            }
                            if(!success) {
                                error "Health check failed!"
                            }
                        }
                    }
                }
            }
        }
    }
}
