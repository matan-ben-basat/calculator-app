pipeline {
    agent { label 'built-in' } 

    environment {
        AWS_ACCOUNT_ID      = '992382545251' 
        AWS_DEFAULT_REGION = 'us-east-1'
        ECR_REGISTRY       = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com"
        IMAGE_NAME         = 'calculator-app'
        PROD_SERVER_IP     = '3.86.214.188' 
    }

    stages {
        stage('CD Flow') {
            when { branch 'main' } 
            stages {
                stage('Build Image (Prod)') {
                    steps {
                       sh "docker build -t ${IMAGE_NAME}:latest ./calculator-app-v2"
                    }
                }
                stage('Test (Prod)') {
                    agent {
                        docker { 
                            image 'python:3.11-slim'
                            reuseNode true 
                        }
                    }
                    steps {
                        dir('calculator-app-v2') {
                            sh 'pip install --target=./packages -r requirements.txt'
                            sh 'PYTHONPATH=./packages python -m unittest discover -s tests -v'
                        }
                    }
                }
                stage('Push to ECR (Prod)') {
                    steps {
                        withCredentials([
                            string(credentialsId: 'aws-access-key-id', variable: 'AWS_ACCESS_KEY_ID'),
                            string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                        ]) {
                            script {
                                // תיקון מוחלט: שימוש בנתיב המלא המוחלט של השרת שלך
                                sh "/usr/local/bin/aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"
                                sh "docker tag ${IMAGE_NAME}:latest ${ECR_REGISTRY}/${IMAGE_NAME}:latest"
                                sh "docker push ${ECR_REGISTRY}/${IMAGE_NAME}:latest"
                            }
                        }
                    }
                }
                stage('Deploy to Production') {
                    steps {
                        withCredentials([sshUserPrivateKey(credentialsId: 'prod-ec2-ssh-key', keyFileVariable: 'IDENTITY_KEY', usernameVariable: 'USER')]) {
                            script {
                                def deployCmd = """
                                    /usr/local/bin/aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY} && \
                                    docker pull ${ECR_REGISTRY}/${IMAGE_NAME}:latest && \
                                    docker stop ${IMAGE_NAME} || true && \
                                    docker rm ${IMAGE_NAME} || true && \
                                    docker run -d --name ${IMAGE_NAME} --restart always -p 80:5000 ${ECR_REGISTRY}/${IMAGE_NAME}:latest
                                """
                                sh "ssh -o StrictHostKeyChecking=no -i \${IDENTITY_KEY} \${USER}@${PROD_SERVER_IP} '${deployCmd}'"
                            }
                        }
                    }
                }
                stage('Health Verification') {
                    steps {
                        script {
                            def maxRetries = 3
                            def success = false
                            for(int i=0; i<maxRetries; i++) {
                                try {
                                    def status = sh(script: "curl -s -o /dev/null -w '%{http_code}' http://${PROD_SERVER_IP}/health", returnStdout: true).trim()
                                    if(status == "200") {
                                        success = true
                                        echo "Application is Healthy!"
                                        break
                                    }
                                } catch(Exception e) {
                                    echo "Waiting for app to spin up..."
                                }
                                sleep(time: 10, unit: 'SECONDS')
                            }
                            if(!success) {
                                error "Health check failed!"
                            }
                        }
                    }
                }
            }
        }
    }
}
